{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "outDir": "./dist/esm",
    "declaration": true,
    "declarationDir": "./dist/esm/types",
    "rootDir": "./src",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "https://cdn.jsdelivr.net/npm/bessa_patterns.ts@0.12.16-alpha/dist/index.mjs": [
        "../bessa_patterns.ts/dist/index.d.ts",
        "./src/types/bessa_patterns.d.ts"
      ],
      "https://cdn.jsdelivr.net/gh/mpbarbosa/olinda_utils.js@0.3.16/dist/vite/index.mjs": [
        "../olinda_utils.js/dist/vite/index.d.ts",
        "./src/types/olinda_utils.d.ts"
      ],
      "https://cdn.jsdelivr.net/gh/mpbarbosa/paraty_geocore.js@0.17.0-alpha/dist/src/index.js": [
        "../paraty_geocore.js/dist/types/src/index.d.ts",
        "./src/types/paraty_geocore.d.ts"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}

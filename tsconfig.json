{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "https://cdn.jsdelivr.net/npm/bessa_patterns.ts@0.12.16-alpha/dist/index.mjs": [
        "../bessa_patterns.ts/dist/index.d.ts",
        "./src/types/bessa_patterns.d.ts"
      ],
      "https://cdn.jsdelivr.net/gh/mpbarbosa/olinda_utils.js@0.3.16/dist/vite/index.mjs": [
        "../olinda_utils.js/dist/vite/index.d.ts",
        "./src/types/olinda_utils.d.ts"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
